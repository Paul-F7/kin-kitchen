PORT=3000

# ── Cloudinary ────────────────────────────────────────────────────────────────
# Required for image upload, LVIS object detection, and AI content analysis.
# Sign up at https://cloudinary.com — enable the "AI Content Analysis" add-on.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Required for Indigenous food context analysis via gemini-2.0-flash.
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# ── Hugging Face ──────────────────────────────────────────────────────────────
# Required for depth estimation (Depth Anything) and BLIP captioning.
# Get a token at https://huggingface.co/settings/tokens
HF_TOKEN=your_hf_token

# ── ElevenLabs ────────────────────────────────────────────────────────────────
# Required for text-to-speech recipe story narration.
# Get a key at https://elevenlabs.io
ELEVENLABS_API_KEY=your_elevenlabs_api_key
